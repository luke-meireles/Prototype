# BluaDiagnostics — referência de variáveis de ambiente
#
# No Google Colab (modo padrão do projeto), NÃO use este arquivo.
# Em vez disso, registre os valores em Colab Secrets:
#
#   Ícone de chave (🔑) na barra lateral → + Add new secret
#     Name:  DASHSCOPE_API_KEY
#     Value: <sua-chave-do-Bailian-Console>
#   Habilite "Notebook access".
#
# Este arquivo é útil apenas para execução local fora do Colab — copie-o para
# `.env` (sem o `.example`) e edite as linhas abaixo.

# Credencial DashScope International (Alibaba Cloud) para Qwen via OpenAI-compatible API
DASHSCOPE_API_KEY=your_key_here

# Endpoint Ollama local (NÃO funciona dentro do Colab — apenas em uso local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelos por backend — fixados na família Qwen
QWEN_DASHSCOPE_MODEL=qwen-plus
QWEN_OLLAMA_MODEL=qwen:9b

# Diretório do ChromaDB persistente (relativo à raiz do projeto)
CHROMA_PERSIST_DIR=./chroma_db
