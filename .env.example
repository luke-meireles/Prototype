# Credencial DashScope International (Alibaba Cloud) para Qwen via OpenAI-compatible API
DASHSCOPE_API_KEY=your_key_here

# Endpoint Ollama local (alternativo ao DashScope)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelos por backend — fixados na família Qwen 3.5
QWEN_DASHSCOPE_MODEL=qwen3.5-plus
QWEN_OLLAMA_MODEL=qwen3.5:9b

# Diretório do ChromaDB persistente
CHROMA_PERSIST_DIR=./chroma_db
